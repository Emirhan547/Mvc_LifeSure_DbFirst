@model Mvc_LifeSure_DbFirst.Dtos.AppUserDtos.RegisterDto
@{
    ViewBag.Title = "Kayıt Ol";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        min-height: 100vh;
    }

    .register-card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.95);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .register-header {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        border-radius: 20px 20px 0 0;
        color: white;
    }

    .form-control {
        height: 48px;
        border-radius: 10px;
    }

    .input-group-text {
        height: 48px;
        border-radius: 10px 0 0 10px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .btn-primary {
        border-radius: 10px;
        height: 50px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13,110,253,0.4);
        }

    .link-hover:hover {
        text-decoration: underline;
    }
</style>

<div class="container d-flex align-items-center justify-content-center" style="min-height:90vh;">
    <div class="col-lg-7">
        <div class="register-card">

            <!-- HEADER -->
            <div class="register-header text-center py-4">
                <h3 class="mb-0">
                    <i class="fas fa-user-plus me-2"></i> LifeSure Kayıt
                </h3>
                <small>Hızlı ve güvenli üyelik oluşturun</small>
            </div>

            <!-- BODY -->
            <div class="p-5">

                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <!-- AD SOYAD -->
                    <div class="row">
                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.FirstName, "Ad", new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Adınız" })
                            @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.LastName, "Soyad", new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Soyadınız" })
                            @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <!-- EMAIL -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Email, "Email", new { @class = "form-label fw-semibold" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-envelope text-primary"></i>
                            </span>
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "ornek@mail.com" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <!-- USERNAME -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.UserName, "Kullanıcı Adı", new { @class = "form-label fw-semibold" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user text-primary"></i>
                            </span>
                            @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "kullaniciadi" })
                        </div>
                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
                    </div>

                    <!-- PASSWORD -->
                    <div class="row">
                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.Password, "Şifre", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-lock text-primary"></i>
                                </span>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifre" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.ConfirmPassword, "Şifre Tekrar", new { @class = "form-label fw-semibold" })
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-lock text-primary"></i>
                                </span>
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Tekrar girin" })
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <!-- CITY PHONE -->
                    <div class="row">
                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.City, "Şehir", new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.City, new { @class = "form-control", placeholder = "İstanbul" })
                            @Html.ValidationMessageFor(m => m.City, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6 form-group">
                            @Html.LabelFor(m => m.PhoneNumber, "Telefon", new { @class = "form-label fw-semibold" })
                            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "05xx xxx xx xx" })
                            @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    <!-- DATE -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.BirthDate, "Doğum Tarihi", new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.BirthDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.BirthDate, "", new { @class = "text-danger small" })
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-user-plus me-2"></i> Kayıt Ol
                        </button>
                    </div>
                }

                <hr class="my-4" />

                <div class="text-center">
                    <span class="text-muted">Zaten hesabın var mı?</span><br />
                    @Html.ActionLink("Giriş Yap", "Login", null, new { @class = "fw-bold text-primary link-hover" })
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}