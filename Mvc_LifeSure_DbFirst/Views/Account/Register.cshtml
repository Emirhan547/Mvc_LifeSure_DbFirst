@model Mvc_LifeSure_DbFirst.Dtos.AppUserDtos.RegisterDto
@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0">
                        <i class="fas fa-user-plus me-2"></i>Kayıt Ol
                    </h3>
                </div>
                <div class="card-body p-5">
                    @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.FirstName, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.FirstName, new { @class = "form-control", placeholder = "Adınız" })
                                @Html.ValidationMessageFor(m => m.FirstName, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.LastName, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.LastName, new { @class = "form-control", placeholder = "Soyadınız" })
                                @Html.ValidationMessageFor(m => m.LastName, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-bold" })
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-envelope text-primary"></i>
                                </span>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Email adresiniz" })
                            </div>
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            @Html.LabelFor(m => m.UserName, new { @class = "form-label fw-bold" })
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i class="fas fa-user text-primary"></i>
                                </span>
                                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Kullanıcı adınız" })
                            </div>
                            @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.Password, new { @class = "form-label fw-bold" })
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="fas fa-lock text-primary"></i>
                                    </span>
                                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifre" })
                                </div>
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-bold" })
                                <div class="input-group">
                                    <span class="input-group-text bg-light">
                                        <i class="fas fa-lock text-primary"></i>
                                    </span>
                                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Şifre tekrar" })
                                </div>
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.City, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.City, new { @class = "form-control", placeholder = "Şehir" })
                                @Html.ValidationMessageFor(m => m.City, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6 mb-3">
                                @Html.LabelFor(m => m.PhoneNumber, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "Telefon" })
                                @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="mb-4">
                            @Html.LabelFor(m => m.BirthDate, new { @class = "form-label fw-bold" })
                            @Html.TextBoxFor(m => m.BirthDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                            @Html.ValidationMessageFor(m => m.BirthDate, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus me-2"></i>Kayıt Ol
                            </button>
                        </div>
                    }

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="mb-0">
                            Zaten hesabınız var mı? @Html.ActionLink("Giriş Yap", "Login", null, new { @class = "text-primary fw-bold text-decoration-none" })
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}

