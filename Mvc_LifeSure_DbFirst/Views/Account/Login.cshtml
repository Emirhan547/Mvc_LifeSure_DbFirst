@model Mvc_LifeSure_DbFirst.Dtos.AppUserDtos.LoginDto
@{
    ViewBag.Title = "Giriş Yap";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        min-height: 100vh;
    }

    .login-card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.9);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .login-header {
        background: linear-gradient(135deg, #0d6efd, #0dcaf0);
        border-radius: 20px 20px 0 0;
        color: white;
    }

    .form-control {
        border-radius: 10px;
        padding: 12px;
    }

    .input-group-text {
        border-radius: 10px 0 0 10px;
    }

    .btn-primary {
        border-radius: 10px;
        padding: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13,110,253,0.4);
        }

    .link-hover:hover {
        text-decoration: underline;
    }
</style>

<div class="container d-flex align-items-center justify-content-center" style="min-height:90vh;">
    <div class="col-md-6 col-lg-5">
        <div class="login-card">

            <!-- HEADER -->
            <div class="login-header text-center py-4">
                <h3 class="mb-0">
                    <i class="fas fa-shield-alt me-2"></i> LifeSure
                </h3>
                <small>Sigorta Yönetim Sistemi</small>
            </div>

            <!-- BODY -->
            <div class="p-5">

                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    <!-- USERNAME -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.UserName, "Kullanıcı Adı", new { @class = "form-label fw-bold" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user text-primary"></i>
                            </span>
                            @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", placeholder = "Kullanıcı adınızı girin" })
                        </div>
                        @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Password, "Şifre", new { @class = "form-label fw-bold" })
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-lock text-primary"></i>
                            </span>
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Şifrenizi girin" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    <!-- REMEMBER -->
                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                            @Html.LabelFor(m => m.RememberMe, "Beni Hatırla", new { @class = "form-check-label" })
                        </div>

                        <div>
                            @Html.ActionLink("Şifremi Unuttum", "ForgotPassword", null, new { @class = "text-primary small link-hover" })
                        </div>
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i> Giriş Yap
                        </button>
                    </div>
                }

                <hr class="my-4" />

                <!-- REGISTER -->
                <div class="text-center">
                    <span class="text-muted">Hesabınız yok mu?</span><br />
                    @Html.ActionLink("Hemen Kayıt Ol", "Register", null, new { @class = "fw-bold text-primary link-hover" })
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}