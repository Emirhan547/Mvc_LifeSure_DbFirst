@model Mvc_LifeSure_DbFirst.ViewModels.ProfileViewModel
@{
    ViewBag.Title = "Profile";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-body text-center p-4">
                    <div class="avatar-circle mx-auto mb-4 bg-primary text-white d-flex align-items-center justify-content-center" style="width: 120px; height: 120px; border-radius: 50%; font-size: 48px;">
                        @Model.FirstName?.Substring(0, 1)@Model.LastName?.Substring(0, 1)
                    </div>
                    <h4 class="fw-bold">@Model.FirstName @Model.LastName</h4>
                    <p class="text-muted">
                        <i class="fas fa-map-marker-alt me-1"></i> @(Model.City ?? "Şehir belirtilmemiş")
                    </p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="@Url.Action("EditProfile")" class="btn btn-primary">
                            <i class="fas fa-edit me-2"></i>Profili Düzenle
                        </a>
                        <a href="@Url.Action("ChangePassword")" class="btn btn-outline-primary">
                            <i class="fas fa-key me-2"></i>Şifre Değiştir
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow border-0 rounded-lg mb-4">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Profil Bilgileri</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Ad Soyad:</div>
                        <div class="col-sm-8">@Model.FirstName @Model.LastName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Kullanıcı Adı:</div>
                        <div class="col-sm-8">@Model.UserName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Email:</div>
                        <div class="col-sm-8">@Model.Email</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Telefon:</div>
                        <div class="col-sm-8">@(Model.PhoneNumber ?? "Belirtilmemiş")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Doğum Tarihi:</div>
                        <div class="col-sm-8">@(Model.BirthDate?.ToString("dd MMMM yyyy") ?? "Belirtilmemiş")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Kayıt Tarihi:</div>
                        <div class="col-sm-8">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4 fw-bold">Poliçe Sayısı:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-primary rounded-pill px-3 py-2">@Model.PolicyCount Poliçe</span>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.PolicyCount > 0)
            {
                <div class="card shadow border-0 rounded-lg">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="fas fa-file-contract me-2"></i>Son Poliçelerim</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-center text-muted my-3">
                            Poliçelerinizi görüntülemek için
                            <a href="@Url.Action("MyPolicies", "Policy")" class="text-primary">tıklayın</a>
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

