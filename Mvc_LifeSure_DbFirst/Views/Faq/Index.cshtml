    @model List<Mvc_LifeSure_DbFirst.Dtos.FaqDtos.ResultFaqDto>

    <div class="container-fluid faq-section bg-light py-5">
        <div class="container py-5">
            <div class="row g-5 align-items-center">
                <div class="col-xl-6 wow fadeInLeft" data-wow-delay="0.2s">
                    <div class="h-100">
                        <div class="mb-5">
                            <h4 class="text-primary">Some Important FAQ's</h4>
                            <h1 class="display-4 mb-0">Common Frequently Asked Questions</h1>
                        </div>
                        <div class="accordion" id="accordionExample">
                           
                                        @if (Model != null)
                                        {
                                            var index = 0;
                                            foreach (var item in Model)
                                            {
                                                var headingId = "heading" + index;
                                                var collapseId = "collapse" + index;
                                                var expanded = index == 0 ? "true" : "false";
                                                var buttonClass = index == 0 ? "accordion-button border-0" : "accordion-button collapsed";
                                                var collapseClass = index == 0 ? "accordion-collapse collapse show active" : "accordion-collapse collapse";
                                                <div class="accordion-item">
                                                    <h2 class="accordion-header" id="@headingId">
                                                        <button class="@buttonClass" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@expanded" aria-controls="@collapseId">
                                                            Q: @item.Question
                                                        </button>
                                                    </h2>
                                                    <div id="@collapseId" class="@collapseClass" aria-labelledby="@headingId" data-bs-parent="#accordionExample">
                                                        <div class="accordion-body rounded">A: @item.Answer</div>
                                                    </div>
                                                </div>
                                           
                                        index++;
                                    }
                                }
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-6 wow fadeInRight" data-wow-delay="0.4s">
                                <img src="@(Model?.FirstOrDefault()?.ImageUrl ?? "img/carousel-2.png")" class="img-fluid w-100" alt="">
                            </div>
                        </div>
                    </div>
                </div>
