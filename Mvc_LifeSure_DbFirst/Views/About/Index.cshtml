@model List<Mvc_LifeSure_DbFirst.Dtos.AboutDtos.ResultAboutDto>

@{
    var about = Model?.FirstOrDefault();
}

<div class="container-fluid bg-light about pb-5">
    <div class="container pb-5">
        <div class="row g-5">
            <div class="col-xl-6 wow fadeInLeft" data-wow-delay="0.2s">
                <div class="about-item-content bg-white rounded p-5 h-100">
                    <h4 class="text-primary">Hakkımızda</h4>

                    <h1 class="display-4 mb-4">@(about?.Title ?? "Geniş Kapsamlı Güvence Çözümleri")</h1>
                    <p>@(about?.Description1 ?? "Müşterilerimize en iyi sigorta hizmetlerini sunmayı hedefliyoruz.")</p>
                    <p>@(about?.Description2 ?? "Güvenilir ve sürdürülebilir çözümlerle her zaman yanınızdayız.")</p>

                    <p class="text-dark"><i class="fa fa-check text-primary me-3"></i>Size tasarruf sağlarız.</p>
                    <p class="text-dark"><i class="fa fa-check text-primary me-3"></i>Kaliteli hizmet sunarız.</p>
                    <p class="text-dark mb-4"><i class="fa fa-check text-primary me-3"></i>Esnek hayat sigortası seçenekleri</p>

                    <a class="btn btn-primary rounded-pill py-3 px-5" href="#">Daha Fazla Bilgi</a>
                </div>
            </div>

            <div class="col-xl-6 wow fadeInRight" data-wow-delay="0.2s">
                <div class="bg-white rounded p-5 h-100">
                    <div class="row g-4 justify-content-center">

                        <div class="col-12">
                            <div class="rounded bg-light">
                                <img src="@(about?.ImageUrl ?? "img/about-1.png")" class="img-fluid rounded w-100" alt="">
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="counter-item bg-light rounded p-3 h-100">
                                <div class="counter-counting">
                                    <span class="text-primary fs-2 fw-bold" data-toggle="counter-up">129</span>
                                    <span class="h1 fw-bold text-primary">+</span>
                                </div>
                                <h4 class="mb-0 text-dark">Sigorta Poliçesi</h4>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="counter-item bg-light rounded p-3 h-100">
                                <div class="counter-counting">
                                    <span class="text-primary fs-2 fw-bold" data-toggle="counter-up">99</span>
                                    <span class="h1 fw-bold text-primary">+</span>
                                </div>
                                <h4 class="mb-0 text-dark">Kazanılan Ödül</h4>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="counter-item bg-light rounded p-3 h-100">
                                <div class="counter-counting">
                                    <span class="text-primary fs-2 fw-bold" data-toggle="counter-up">556</span>
                                    <span class="h1 fw-bold text-primary">+</span>
                                </div>
                                <h4 class="mb-0 text-dark">Uzman Acenta</h4>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="counter-item bg-light rounded p-3 h-100">
                                <div class="counter-counting">
                                    <span class="text-primary fs-2 fw-bold" data-toggle="counter-up">967</span>
                                    <span class="h1 fw-bold text-primary">+</span>
                                </div>
                                <h4 class="mb-0 text-dark">Ekip Üyesi</h4>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>