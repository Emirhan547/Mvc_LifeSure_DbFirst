@model Mvc_LifeSure_DbFirst.Dtos.ServiceDtos.CreateServicesDto
@{
    ViewBag.Title = "Hizmet Ekle";
    ViewBag.PageTitle = "Hizmet Ekle";
    ViewBag.BreadcrumbTitle = "Yeni Hizmet";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-8">
    <div class="max-w-4xl mx-auto bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-200 bg-slate-50">
            <h2 class="text-xl font-semibold text-slate-800">Yeni Hizmet Kaydı</h2>
            <p class="text-sm text-slate-500 mt-1">Formu doldurarak dinamik içeriği ekleyin.</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Başlık</label>
                    @Html.TextBoxFor(x => x.Title, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.Title, "", new { @class = "text-rose-600 text-xs" })
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Açıklama</label>
                    @Html.TextBoxFor(x => x.Description, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.Description, "", new { @class = "text-rose-600 text-xs" })
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Görsel URL</label>
                    @Html.TextBoxFor(x => x.ImageUrl, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.ImageUrl, "", new { @class = "text-rose-600 text-xs" })
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">İkon</label>
                    @Html.TextBoxFor(x => x.Icon, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.Icon, "", new { @class = "text-rose-600 text-xs" })
                </div>
            </div>

            <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-end gap-3">
                <a href="/Admin/Service/Index" class="px-4 py-2 rounded-xl border border-slate-300 text-slate-600 hover:bg-slate-100 transition-colors">Vazgeç</a>
                <button type="submit" class="px-5 py-2 rounded-xl bg-primary text-white font-medium hover:bg-cyan-600 transition-colors">Kaydet</button>
            </div>
        }
    </div>
</div>