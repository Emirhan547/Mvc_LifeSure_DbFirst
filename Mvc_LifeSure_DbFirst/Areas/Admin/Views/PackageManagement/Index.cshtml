@model IEnumerable<Mvc_LifeSure_DbFirst.Dtos.InsurancePackageDtos.ResultInsurancePackageDto>
@{
    ViewBag.Title = "Paket Yönetimi";
    ViewBag.PageTitle = "Paket Yönetimi";
    ViewBag.BreadcrumbTitle = "Paketler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


        <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
            <h1 class="text-2xl font-bold">Sigorta Paket Yönetimi</h1>
            <p class="mt-1 text-sm text-white/90">Paketleri görüntüleyin, durumlarını güncelleyin ve yeni paket oluşturun.</p>
        </div>

      
                            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                                <div class="p-5 border-b border-slate-200 flex items-center justify-between">
                                    <h2 class="text-lg font-semibold text-slate-800">Paket Listesi</h2>
                                    <a href="@Url.Action("Create")" class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-medium hover:bg-cyan-600 transition-colors">Yeni Paket</a>
                                </div>

                                <div class="overflow-x-auto">
                                    <table class="w-full text-sm">
                                        <thead class="bg-slate-50 text-left text-slate-700 font-semibold">
                                            <tr>
                                                <th class="px-4 py-3">Paket</th>
                                                <th class="px-4 py-3">Fiyat</th>
                                                <th class="px-4 py-3">Süre</th>
                                                <th class="px-4 py-3">Durum</th>
                                                <th class="px-4 py-3 text-right">İşlem</th>
                                            </tr>
                                           
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-t border-slate-100 hover:bg-slate-50/70">
                                <td class="px-4 py-3 text-slate-600">@item.PackageName</td>
                                <td class="px-4 py-3 text-slate-600">@item.BasePrice.ToString("C")</td>
                                <td class="px-4 py-3 text-slate-600">@item.CoveragePeriodMonths Ay</td>
                                <td class="px-4 py-3">
                                    <span class="px-2 py-1 rounded-lg text-xs font-medium @(item.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-rose-100 text-rose-700")">@(item.IsActive ? "Aktif" : "Pasif")</span>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex justify-end gap-2">
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="px-3 py-1.5 rounded-lg bg-sky-100 text-sky-700 font-medium">Detay</a>
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="px-3 py-1.5 rounded-lg bg-amber-100 text-amber-700 font-medium">Düzenle</a>
                                        <button class="px-3 py-1.5 rounded-lg bg-violet-100 text-violet-700 font-medium toggle-btn" data-id="@item.Id">Durum</button>
                                        <button class="px-3 py-1.5 rounded-lg bg-rose-100 text-rose-700 font-medium delete-btn" data-id="@item.Id">Sil</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="px-4 py-10 text-center text-slate-500">Henüz paket bulunmuyor.</td></tr>
                    }
                </tbody>
                </table>
            </div>
        </div>
    

    @section Scripts {
        <script>
$(function(){
    $('.toggle-btn').click(function(){ $.post('@Url.Action("ToggleStatus")',{id:$(this).data('id')},function(r){ if(r.success) location.reload(); else alert(r.message||'Hata');});});
    $('.delete-btn').click(function(){ if(!confirm('Paket silinsin mi?')) return; $.post('@Url.Action("Delete")',{id:$(this).data('id')},function(r){ if(r.success) location.reload(); else alert(r.message||'Hata');});});
});
        </script>
    
}