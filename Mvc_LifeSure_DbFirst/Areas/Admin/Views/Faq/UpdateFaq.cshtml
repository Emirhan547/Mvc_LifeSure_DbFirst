@model Mvc_LifeSure_DbFirst.Dtos.FaqDtos.UpdateFaqDto
@{
    ViewBag.Title = "Sık Sorular Güncelle";
    ViewBag.PageTitle = "Sık Sorular Güncelle";
    ViewBag.BreadcrumbTitle = "Sık Sorular Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-8">
    <div class="max-w-4xl mx-auto bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="p-6 border-b border-slate-200 bg-slate-50">
            <h2 class="text-xl font-semibold text-slate-800">Sık Sorular Kaydını Düzenle</h2>
            <p class="text-sm text-slate-500 mt-1">Değişiklikleri kaydederek içerikleri canlı olarak güncelleyebilirsiniz.</p>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.Id)
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Soru</label>
                    @Html.TextBoxFor(x => x.Question, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.Question, "", new { @class = "text-rose-600 text-xs" })
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Cevap</label>
                    @Html.TextBoxFor(x => x.Answer, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.Answer, "", new { @class = "text-rose-600 text-xs" })
                </div>
                <div class="space-y-2">
                    <label class="block text-sm font-medium text-slate-700">Görsel URL</label>
                    @Html.TextBoxFor(x => x.ImageUrl, new { @class = "w-full rounded-xl border-slate-300 focus:border-primary focus:ring-primary text-sm" })
                    @Html.ValidationMessageFor(x => x.ImageUrl, "", new { @class = "text-rose-600 text-xs" })
                </div>
            </div>

            <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-end gap-3">
                <a href="/Admin/Faq/Index" class="px-4 py-2 rounded-xl border border-slate-300 text-slate-600 hover:bg-slate-100 transition-colors">Vazgeç</a>
                <button type="submit" class="px-5 py-2 rounded-xl bg-primary text-white font-medium hover:bg-cyan-600 transition-colors">Güncelle</button>
            </div>
        }
    </div>
</div>