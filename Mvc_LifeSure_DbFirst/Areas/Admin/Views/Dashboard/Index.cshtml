@{
    ViewBag.Title = "Dashboard";
    ViewBag.PageTitle = "Dashboard";
    ViewBag.BreadcrumbTitle = "Ana Sayfa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Kullanıcı</h6>
                        <h3 class="text-white mb-0">@ViewBag.TotalUsers</h3>
                    </div>
                    <div class="icon-circle bg-white-20">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <small class="text-white-50">
                    <i class="fas fa-arrow-up me-1"></i>aktif kullanıcılar
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card bg-success text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Poliçe</h6>
                        <h3 class="text-white mb-0">@ViewBag.TotalPolicies</h3>
                    </div>
                    <div class="icon-circle bg-white-20">
                        <i class="fas fa-file-contract fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <small class="text-white-50">
                    <i class="fas fa-arrow-up me-1"></i>aktif poliçeler
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card bg-info text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Aktif Paketler</h6>
                        <h3 class="text-white mb-0">@ViewBag.ActivePackages</h3>
                    </div>
                    <div class="icon-circle bg-white-20">
                        <i class="fas fa-box fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <small class="text-white-50">
                    <i class="fas fa-arrow-up me-1"></i>toplam @ViewBag.TotalPackages paket
                </small>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card bg-warning text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50 mb-2">Toplam Prim</h6>
                        <h3 class="text-white mb-0">@ViewBag.TotalPremium.ToString("C0")</h3>
                    </div>
                    <div class="icon-circle bg-white-20">
                        <i class="fas fa-money-bill-wave fa-2x"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0">
                <small class="text-white-50">
                    <i class="fas fa-arrow-up me-1"></i>toplam prim tutarı
                </small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-6">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Şehir Bazlı Poliçe Dağılımı</h5>
            </div>
            <div class="card-body">
                <canvas id="cityChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-history me-2"></i>Son İşlem Logları</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Kullanıcı</th>
                                <th>İşlem</th>
                                <th>Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentLogs != null && ViewBag.RecentLogs.Count > 0)
                            {
                                foreach (var log in ViewBag.RecentLogs)
                                {
                                    <tr>
                                        <td>@log.UserName</td>
                                        <td>@log.Action</td>
                                        <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-3">Henüz log kaydı yok</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-file-contract me-2"></i>Son Poliçeler</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Poliçe No</th>
                                <th>Müşteri</th>
                                <th>Paket</th>
                                <th>Başlangıç</th>
                                <th>Prim</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentPolicies != null && ViewBag.RecentPolicies.Count > 0)
                            {
                                foreach (var policy in ViewBag.RecentPolicies)
                                {
                                    <tr>
                                        <td>@policy.PolicyNumber</td>
                                        <td>@policy.UserFullName</td>
                                        <td>@policy.PackageName</td>
                                        <td>@policy.StartDate.ToString("dd.MM.yyyy")</td>
                                        <td>@policy.PremiumAmount.ToString("C0")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">Henüz poliçe kaydı yok</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            var ctx = document.getElementById('cityChart').getContext('2d');
            var cityData = @Html.Raw(Json.Encode(ViewBag.CityDistribution));

            var cities = Object.keys(cityData);
            var counts = Object.values(cityData);

            new Chart(ctx, {
                type: 'pie',
                data: {
                    labels: cities,
                    datasets: [{
                        data: counts,
                        backgroundColor: [
                            '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b',
                            '#5a5c69', '#858796', '#6f42c1', '#fd7e14', '#20c9a6'
                        ]
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        });
    </script>
}