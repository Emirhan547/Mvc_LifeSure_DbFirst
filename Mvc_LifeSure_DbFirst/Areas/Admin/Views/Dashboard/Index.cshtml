@using System.Collections.Generic
@using System.Linq
@model Mvc_LifeSure_DbFirst.Dtos.DashboardDtos.AdminDashboardViewModel

@{
    ViewBag.Title = "Dashboard";
    ViewBag.PageTitle = "Dashboard";
    ViewBag.BreadcrumbTitle = "Ana Sayfa";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var cityDistribution = Model.CityDistribution ?? new Dictionary<string, int>();
    var premiumDistribution = Model.PremiumDistribution ?? new Dictionary<string, decimal>();
}

<div class="p-8 space-y-6">
    <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <div>
                <h1 class="text-2xl font-bold">Operasyon Dashboard'u</h1>
                <p class="mt-1 text-sm text-white/90">
                    Admin panelindeki kullanıcı, poliçe, gelir ve operasyon trafiğini tek ekranda izleyin.
                </p>
            </div>

            <div class="grid grid-cols-2 gap-3 text-sm">
                <a href="@Url.Action("Index", "PolicyManagement")"
                   class="rounded-xl bg-white/15 px-4 py-3 font-medium text-white hover:bg-white/20 transition-colors">
                    Poliçe Yönetimi
                </a>
                <a href="@Url.Action("Index", "UserManagement")"
                   class="rounded-xl bg-white/15 px-4 py-3 font-medium text-white hover:bg-white/20 transition-colors">
                    Kullanıcı Yönetimi
                </a>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-2xl bg-white border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Toplam Kullanıcı</p>
            <p class="mt-3 text-3xl font-bold text-slate-800">@Model.TotalUsers</p>
            <p class="mt-2 text-xs text-slate-500">Sistemde tanımlı tüm kullanıcılar</p>
        </div>

        <div class="rounded-2xl bg-white border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Aktif Poliçeler</p>
            <p class="mt-3 text-3xl font-bold text-slate-800">@Model.ActivePolicies / @Model.TotalPolicies</p>
            <p class="mt-2 text-xs text-slate-500">Süresi dolmamış poliçeler</p>
        </div>

        <div class="rounded-2xl bg-white border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Yenileme Takibinde</p>
            <p class="mt-3 text-3xl font-bold text-amber-600">@Model.ExpiringPolicies</p>
            <p class="mt-2 text-xs text-slate-500">Yenileme takibi gerektiren poliçeler</p>
        </div>

        <div class="rounded-2xl bg-white border border-slate-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Toplam Prim / Ort. Prim</p>
            <p class="mt-3 text-2xl font-bold text-slate-800">@Model.TotalPremium.ToString("C0")</p>
            <p class="mt-2 text-xs text-slate-500">
                Ortalama: @Model.AveragePremium.ToString("C0")
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
        <div class="xl:col-span-2 rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
            <div class="border-b border-slate-200 px-5 py-4 flex items-center justify-between">
                <div>
                    <h2 class="text-lg font-semibold text-slate-800">Poliçe ve gelir görünümü</h2>
                    <p class="text-sm text-slate-500">Şehir bazlı hacim ve prim dağılımı</p>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-6 p-5 lg:grid-cols-2">
                <div>
                    <h3 class="mb-3 text-sm font-semibold text-slate-700">
                        Şehir Bazlı Poliçe Dağılımı
                    </h3>
                    <canvas id="cityChart" style="max-height: 280px;"></canvas>
                </div>
                <div>
                    <h3 class="mb-3 text-sm font-semibold text-slate-700">
                        Şehir Bazlı Prim Tutarı
                    </h3>
                    <canvas id="premiumChart" style="max-height: 280px;"></canvas>
                </div>
            </div>
        </div>

        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
            <div class="border-b border-slate-200 px-5 py-4">
                <h2 class="text-lg font-semibold text-slate-800">Operasyon özeti</h2>
            </div>

            <div class="space-y-4 p-5">
                <div class="rounded-xl bg-slate-50 p-4">
                    <p class="text-sm text-slate-500">Aktif Paketler</p>
                    <p class="mt-1 text-2xl font-bold text-slate-800">
                        @Model.ActivePackages / @Model.TotalPackages
                    </p>
                </div>

                <div class="rounded-xl bg-slate-50 p-4">
                    <p class="text-sm text-slate-500">Son 8 İşlem</p>
                    <p class="mt-1 text-2xl font-bold text-slate-800">
                        @Model.RecentLogs.Count
                    </p>
                </div>

                <div class="rounded-xl bg-amber-50 border border-amber-100 p-4">
                    <p class="text-sm font-medium text-amber-700">Yenileme odağı</p>
                    <p class="mt-1 text-sm text-amber-800">
                        Önümüzdeki 30 günde biten poliçeler için yenileme aksiyonu planlanmalı.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
            <div class="border-b border-slate-200 px-5 py-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Yenileme bekleyen poliçeler</h2>
                <a href="@Url.Action("Index", "PolicyManagement")" class="text-sm font-medium text-primary">
                    Tümünü Gör
                </a>
            </div>

            <div class="divide-y divide-slate-100">
                @if (Model.ExpiringPolicyList.Any())
                {
                    foreach (var policy in Model.ExpiringPolicyList)
                    {
                        <div class="flex items-center justify-between px-5 py-4">
                            <div>
                                <p class="font-medium text-slate-800">
                                    @policy.PolicyNumber - @policy.UserFullName
                                </p>
                                <p class="text-sm text-slate-500">@policy.PackageName</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-semibold text-amber-600">
                                    @policy.EndDate.ToString("dd.MM.yyyy")
                                </p>
                                <p class="text-xs text-slate-500">
                                    @policy.PremiumAmount.ToString("C0")
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="px-5 py-8 text-sm text-slate-500">
                        Önümüzdeki 30 gün içinde bitecek poliçe bulunmuyor.
                    </div>
                }
            </div>
        </div>

        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
            <div class="border-b border-slate-200 px-5 py-4 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-slate-800">Son işlem logları</h2>
                <span class="text-sm text-slate-500">@Model.RecentLogs.Count kayıt</span>
            </div>

            <div class="divide-y divide-slate-100">
                @if (Model.RecentLogs.Any())
                {
                    foreach (var log in Model.RecentLogs)
                    {
                        <div class="px-5 py-4">
                            <div class="flex items-center justify-between gap-3">
                                <p class="font-medium text-slate-800">
                                    @(string.IsNullOrWhiteSpace(log.UserName) ? "Sistem" : log.UserName)
                                </p>
                                <span class="text-xs text-slate-500">
                                    @log.Timestamp.ToString("dd.MM.yyyy HH:mm")
                                </span>
                            </div>
                            <p class="mt-1 text-sm text-slate-600">@log.Action</p>
                            <p class="mt-1 text-xs text-slate-400">
                                @log.TableName / @log.ActionType
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div class="px-5 py-8 text-sm text-slate-500">
                        Henüz log kaydı yok.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
        <div class="border-b border-slate-200 px-5 py-4 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-slate-800">Son poliçeler</h2>
            <a href="@Url.Action("Index", "PolicyManagement")" class="text-sm font-medium text-primary">
                Poliçelere Git
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead class="bg-slate-50 text-slate-600">
                    <tr>
                        <th class="px-5 py-3 text-left font-semibold">Poliçe</th>
                        <th class="px-5 py-3 text-left font-semibold">Müşteri</th>
                        <th class="px-5 py-3 text-left font-semibold">Paket</th>
                        <th class="px-5 py-3 text-left font-semibold">Başlangıç</th>
                        <th class="px-5 py-3 text-left font-semibold">Prim</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentPolicies.Any())
                    {
                        foreach (var policy in Model.RecentPolicies)
                        {
                            <tr class="border-t border-slate-100">
                                <td class="px-5 py-3 text-slate-700">@policy.PolicyNumber</td>
                                <td class="px-5 py-3 text-slate-700">@policy.UserFullName</td>
                                <td class="px-5 py-3 text-slate-700">@policy.PackageName</td>
                                <td class="px-5 py-3 text-slate-700">@policy.StartDate.ToString("dd.MM.yyyy")</td>
                                <td class="px-5 py-3 text-slate-700">@policy.PremiumAmount.ToString("C0")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-5 py-8 text-center text-slate-500">
                                Henüz poliçe kaydı yok.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $(function () {
            var cityData = @Html.Raw(Json.Encode(cityDistribution));
            var premiumData = @Html.Raw(Json.Encode(premiumDistribution));

            new Chart(document.getElementById('cityChart'), {
                type: 'doughnut',
                data: {
                    labels: Object.keys(cityData),
                    datasets: [{
                        data: Object.values(cityData),
                        backgroundColor: ['#0ea5e9', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#14b8a6']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } }
                }
            });

            new Chart(document.getElementById('premiumChart'), {
                type: 'bar',
                data: {
                    labels: Object.keys(premiumData),
                    datasets: [{
                        label: 'Prim Tutarı',
                        data: Object.values(premiumData),
                        backgroundColor: '#1193d4',
                        borderRadius: 12
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        });
    </script>
}