@model IEnumerable<Mvc_LifeSure_DbFirst.Dtos.PolicyDtos.ResultPolicyDto>
@using Mvc_LifeSure_DbFirst.Dtos.AppUserDtos
@{
    ViewBag.Title = "Kullanıcı Poliçeleri";
    ViewBag.PageTitle = "Kullanıcı Poliçeleri";
    ViewBag.BreadcrumbTitle = "Poliçeler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var user = ViewBag.User as ResultAppUserDto;
}


        <div class="p-8 space-y-6">
            <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
                <h1 class="text-2xl font-bold">Kullanıcı Poliçeleri</h1>
                <p class="mt-1 text-sm text-white/90">@(user != null ? user.FirstName + " " + user.LastName : "Kullanıcı") adına kayıtlı poliçeler.</p>
            </div>

                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="p-5 border-b border-slate-200">
                        <h2 class="text-lg font-semibold text-slate-800">Poliçe Geçmişi</h2>
                    </div>
                    <table class="w-full text-sm">
                        <thead class="bg-slate-50"><tr><th class="px-4 py-3 text-left text-slate-700">No</th><th class="px-4 py-3 text-left text-slate-700">Paket</th><th class="px-4 py-3 text-left text-slate-700">Prim</th><th class="px-4 py-3 text-left text-slate-700">Bitiş</th></tr></thead>
                        <tbody>
                          
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr class="border-t border-slate-100 hover:bg-slate-50/70"><td class="px-4 py-3 text-slate-600">@item.PolicyNumber</td><td class="px-4 py-3 text-slate-600">@item.PackageName</td><td class="px-4 py-3 text-slate-600">@item.PremiumAmount.ToString("C")</td><td class="px-4 py-3 text-slate-600">@item.EndDate.ToString("dd.MM.yyyy")</td></tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="px-4 py-10 text-center text-slate-500">Kullanıcıya ait poliçe kaydı bulunmuyor.</td></tr>
                                }
                        </tbody>
                    </table>
                </div>
            </div>
       
