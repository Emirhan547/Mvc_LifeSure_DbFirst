@model Mvc_LifeSure_DbFirst.Dtos.PolicyDtos.ResultPolicyDto
@{
    ViewBag.Title = "Poliçe Detayı";
    ViewBag.PageTitle = "Poliçe Detayı";
    ViewBag.BreadcrumbTitle = "Poliçeler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-8">
    <div class="max-w-3xl bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 space-y-2">
        <h2 class="text-xl font-semibold">@Model.PolicyNumber</h2>
        <p><strong>Müşteri:</strong> @Model.UserFullName (@Model.UserEmail)</p>
        <p><strong>Şehir:</strong> @Model.UserCity</p>
        <p><strong>Paket:</strong> @Model.PackageName</p>
        <p><strong>Prim:</strong> @Model.PremiumAmount.ToString("C")</p>
        <p><strong>Başlangıç:</strong> @Model.StartDate.ToString("dd.MM.yyyy")</p>
        <p><strong>Bitiş:</strong> @Model.EndDate.ToString("dd.MM.yyyy")</p>
        <a href="@Url.Action("Index")" class="inline-block mt-2 px-4 py-2 rounded-xl bg-primary text-white">Listeye Dön</a>
    </div>
</div>