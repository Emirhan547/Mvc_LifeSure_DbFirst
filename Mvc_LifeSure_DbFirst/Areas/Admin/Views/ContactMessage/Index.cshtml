@model IEnumerable<Mvc_LifeSure_DbFirst.Dtos.ContactMessageDtos.ResultContactMessageDto>
@{
    ViewBag.Title = "İletişim Mesajları";
    ViewBag.PageTitle = "İletişim Mesajları";
    ViewBag.BreadcrumbTitle = "Mesaj Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var stats = ViewBag.Stats as Dictionary<string, int>;
}

<div class="p-8 space-y-6">
    
        <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
            <h1 class="text-2xl font-bold">Gelen İletişim Mesajları</h1>
            <p class="mt-1 text-sm text-white/90">Mesajları inceleyin, yeniden işleyin ve cevap durumlarını takip edin.</p>
        </div>

       

                        <div class="rounded-2xl bg-white border border-slate-200 shadow-sm overflow-hidden">
                            <div class="p-5 border-b border-slate-200 flex items-center justify-between">
                                <h2 class="text-lg font-semibold text-slate-800">Gelen Mesajlar</h2>
                                <a href="@Url.Action("Unreplied")" class="px-4 py-2 rounded-xl bg-primary text-white text-sm font-medium hover:bg-cyan-600 transition-colors">Sadece Cevaplanmayanlar</a>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full min-w-[900px] text-sm">
                                    <thead class="bg-slate-50 text-left text-slate-700 font-semibold">
                                        <tr>
                                            <th class="px-4 py-3">Gönderen</th>
                                            <th class="px-4 py-3">Email</th>
                            
                                            <th class="px-4 py-3">Durum</th>
                                            <th class="px-4 py-3">Tarih</th>
                                            <th class="px-4 py-3 text-right">İşlem</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any())
                                        {
                                            foreach (var item in Model)
                                            {

                                                <tr class="border-t border-slate-100 hover:bg-slate-50/70">
                                                    <td class="px-4 py-3 text-slate-600">@item.Name</td>
                                                    <td class="px-4 py-3 text-slate-600">@item.Email</td>

                                                    <td class="px-4 py-3">
                                                        @if (item.IsReplied)
                                                        {<span class="px-2 py-1 rounded-lg bg-emerald-100 text-emerald-700 text-xs font-medium">Cevaplandı</span> }
                                                        else
                                                        { <span class="px-2 py-1 rounded-lg bg-amber-100 text-amber-700 text-xs font-medium">Bekliyor</span>}
                                                    </td>
                                                    <td class="px-4 py-3 text-slate-600">@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                                    <td class="px-4 py-3">
                                                        <div class="flex justify-end gap-2">

                                                            <a href="@Url.Action("Details", new { id = item.Id })" class="px-3 py-1.5 rounded-lg bg-sky-100 text-sky-700 font-medium">Detay</a>
                                                            <button class="px-3 py-1.5 rounded-lg bg-violet-100 text-violet-700 font-medium reprocess-btn" data-id="@item.Id">Yeniden İşle</button>
                                                            <button class="px-3 py-1.5 rounded-lg bg-rose-100 text-rose-700 font-medium delete-btn" data-id="@item.Id">Sil</button>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="5" class="px-4 py-8 text-center text-slate-500">Mesaj bulunamadı.</td></tr>
                                        }
                                    </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            @section Scripts {
                                <script>
    $(function () {
        $('.delete-btn').click(function () {
            if (!confirm('Mesaj silinsin mi?')) return;
            $.post('@Url.Action("Delete")', { id: $(this).data('id') }, function (res) {
                if (res.success) location.reload(); else alert(res.message || 'Hata oluştu');
            });
        });

        $('.reprocess-btn').click(function () {
            $.post('@Url.Action("Reprocess")', { id: $(this).data('id') }, function (res) {
                if (res.success) alert('Mesaj tekrar işlendi.'); else alert(res.message || 'Hata oluştu');
            });
        });
    });
                                </script>
                            
                        }
