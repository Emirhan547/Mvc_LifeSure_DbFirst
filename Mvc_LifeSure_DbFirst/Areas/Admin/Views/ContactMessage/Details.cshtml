@model Mvc_LifeSure_DbFirst.Dtos.ContactMessageDtos.ResultContactMessageDto
@{
    ViewBag.Title = "Mesaj Detayı";
    ViewBag.PageTitle = "Mesaj Detayı";
    ViewBag.BreadcrumbTitle = "İletişim";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


        <div class="p-8 space-y-6">
            <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20 max-w-4xl">
                <h1 class="text-2xl font-bold">Mesaj Detayı</h1>
                <p class="mt-1 text-sm text-white/90">Gönderilen mesajın tüm içeriğini ve cevap durumunu inceleyin.</p>
            </div>

            <div class="max-w-4xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
                <h2 class="text-xl font-semibold text-slate-800">@Model.Name</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                    <div class="rounded-xl bg-slate-50 border border-slate-100 px-4 py-3"><strong>Email:</strong> @Model.Email</div>
                    <div class="rounded-xl bg-slate-50 border border-slate-100 px-4 py-3"><strong>Tarih:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                    <div class="rounded-xl bg-slate-50 border border-slate-100 px-4 py-3"><strong>Durum:</strong> @(Model.IsReplied ? "Cevaplandı" : "Cevap Bekliyor")</div>
                </div>

                <div>
                  
                    <h3 class="font-semibold text-slate-800 mb-1">Mesaj</h3>
                    <p class="text-slate-600 whitespace-pre-wrap rounded-xl bg-slate-50 border border-slate-100 px-4 py-3">@Model.Message</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.AutoReply))
                {
                    <div>
                        
                        <h3 class="font-semibold text-slate-800 mb-1">Otomatik Yanıt</h3>
                        <p class="text-slate-600 whitespace-pre-wrap rounded-xl bg-slate-50 border border-slate-100 px-4 py-3">@Model.AutoReply</p>
                    </div>
                }

                <a href="@Url.Action("Index")" class="inline-flex items-center px-4 py-2 rounded-xl bg-primary text-white text-sm font-medium hover:bg-cyan-600 transition-colors">Listeye Dön</a>
            </div>
        </div>
 
