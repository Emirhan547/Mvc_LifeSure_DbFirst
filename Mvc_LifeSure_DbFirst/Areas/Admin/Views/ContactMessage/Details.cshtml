@model Mvc_LifeSure_DbFirst.Dtos.ContactMessageDtos.ResultContactMessageDto
@{
    ViewBag.Title = "Mesaj Detayı";
    ViewBag.PageTitle = "Mesaj Detayı";
    ViewBag.BreadcrumbTitle = "İletişim";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-8">
    <div class="max-w-4xl bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 space-y-4">
        <h2 class="text-xl font-semibold">@Model.Name</h2>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Kategori:</strong> @(Model.Category ?? "-")</p>
        <p><strong>Tarih:</strong> @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Durum:</strong> @(Model.IsReplied ? "Cevaplandı" : "Cevap Bekliyor")</p>

        <div>
            <h3 class="font-semibold mb-1">Mesaj</h3>
            <p class="text-slate-700 dark:text-slate-300 whitespace-pre-wrap">@Model.Message</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.AutoReply))
        {
            <div>
                <h3 class="font-semibold mb-1">Otomatik Yanıt</h3>
                <p class="text-slate-700 dark:text-slate-300 whitespace-pre-wrap">@Model.AutoReply</p>
            </div>
        }

        <a href="@Url.Action("Index")" class="inline-block px-4 py-2 rounded-xl bg-primary text-white">Listeye Dön</a>
    </div>
</div>