@using System.Collections.Generic
@{
    ViewBag.Title = "Rol Yönetimi";
    ViewBag.PageTitle = "Rol Yönetimi";
    ViewBag.BreadcrumbTitle = "Kullanıcı Rolleri";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var userId = ViewBag.UserId as string;
    var userName = ViewBag.UserName as string;
    var userRoles = ViewBag.UserRoles as IList<string>;
    var allRoles = ViewBag.AllRoles as IList<string>;
}


        <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
            <h1 class="text-2xl font-bold">Rol Yönetimi</h1>
            <p class="mt-1 text-sm text-white/90"><strong>@userName</strong> için rol atama ve kaldırma işlemleri.</p>
        </div>

        
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
                    <h3 class="font-semibold text-slate-800 mb-3">Mevcut Roller</h3>
                    <div class="flex flex-wrap gap-2 mb-6">
                        @if (userRoles != null && userRoles.Any())
                        {
                            foreach (var role in userRoles)
                            {
                                <button class="px-3 py-1.5 rounded-lg bg-rose-100 text-rose-700 font-medium remove-role" data-role="@role">@role (Kaldır)</button>
                            }
                        }
                        else
                        {
                            <span class="text-slate-500">Rol bulunmuyor.</span>
                        }
                    </div>

                    <h3 class="font-semibold text-slate-800 mb-3">Rol Ekle</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var role in allRoles ?? new List<string>())
                        {
                            <button class="px-3 py-1.5 rounded-lg bg-emerald-100 text-emerald-700 font-medium add-role" data-role="@role">@role Ekle</button>
                        }
                    </div>
                </div>
           

            @section Scripts {
                <script>
    $(function() {
        $('.add-role').click(function() {
            $.post('@Url.Action("AddRole")', { userId: '@userId', role: $(this).data('role') }, function(r) {
                if (r.success) location.reload(); else alert(r.message || 'Hata');
            });
        });
        $('.remove-role').click(function() {
            $.post('@Url.Action("RemoveRole")', { userId: '@userId', role: $(this).data('role') }, function(r) {
                if (r.success) location.reload(); else alert(r.message || 'Hata');
            });
        });
    });
                </script>
            
            }
