@model Mvc_LifeSure_DbFirst.Dtos.AppUserDtos.ResultAppUserDto
@using System.Collections.Generic
@{
    ViewBag.Title = "Kullanıcı Detayı";
    ViewBag.PageTitle = "Kullanıcı Detayı";
    ViewBag.BreadcrumbTitle = "Kullanıcılar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var roles = ViewBag.UserRoles as IList<string>;
}



        <div class="p-8 space-y-6">
            <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                    <div>
                        <h1 class="text-2xl font-bold">@Model.FirstName @Model.LastName</h1>
                        <p class="mt-1 text-sm text-white/90">Kullanıcının profil, erişim ve poliçe özetini tek ekranda görüntüleyin.</p>
                    </div>
                    <div class="flex flex-wrap gap-3">
                        <a href="@Url.Action("Edit", new { id = Model.Id })" class="rounded-xl bg-white px-4 py-2 text-sm font-semibold text-primary">Bilgileri Düzenle</a>
                        <a href="@Url.Action("ManageRoles", new { id = Model.Id })" class="rounded-xl bg-white/15 px-4 py-2 text-sm font-semibold text-white">Rolleri Yönet</a>
                        <a href="@Url.Action("UserPolicies", "PolicyManagement", new { userId = Model.Id })" class="rounded-xl bg-white/15 px-4 py-2 text-sm font-semibold text-white">Poliçeleri Gör</a>
                    </div>

                </div>
            </div>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"><p class="text-sm text-slate-500">Kullanıcı Adı</p><p class="mt-2 text-xl font-bold text-slate-800">@Model.UserName</p></div>
                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"><p class="text-sm text-slate-500">Poliçe Sayısı</p><p class="mt-2 text-xl font-bold text-slate-800">@Model.PolicyCount</p></div>
                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"><p class="text-sm text-slate-500">Durum</p><p class="mt-2 text-xl font-bold @(Model.IsActive ? "text-emerald-600" : "text-rose-600")">@(Model.IsActive ? "Aktif" : "Pasif")</p></div>
                </div>

                <div class="grid grid-cols-1 gap-6 xl:grid-cols-3">
                    <div class="xl:col-span-2 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm space-y-4">
                        <h2 class="text-lg font-semibold text-slate-800">Profil bilgileri</h2>
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div class="rounded-xl bg-slate-50 px-4 py-3"><span class="block text-xs font-medium uppercase tracking-wide text-slate-400">Email</span><span class="mt-1 block text-slate-700">@Model.Email</span></div>
                            <div class="rounded-xl bg-slate-50 px-4 py-3"><span class="block text-xs font-medium uppercase tracking-wide text-slate-400">Telefon</span><span class="mt-1 block text-slate-700">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Belirtilmemiş" : Model.PhoneNumber)</span></div>
                            <div class="rounded-xl bg-slate-50 px-4 py-3"><span class="block text-xs font-medium uppercase tracking-wide text-slate-400">Şehir</span><span class="mt-1 block text-slate-700">@(string.IsNullOrWhiteSpace(Model.City) ? "Belirtilmemiş" : Model.City)</span></div>
                            <div class="rounded-xl bg-slate-50 px-4 py-3"><span class="block text-xs font-medium uppercase tracking-wide text-slate-400">Doğum Tarihi</span><span class="mt-1 block text-slate-700">@(Model.BirthDate.HasValue ? Model.BirthDate.Value.ToString("dd.MM.yyyy") : "Belirtilmemiş")</span></div>
                            <div class="rounded-xl bg-slate-50 px-4 py-3 md:col-span-2"><span class="block text-xs font-medium uppercase tracking-wide text-slate-400">Roller</span><span class="mt-1 block text-slate-700">@((roles != null && roles.Count > 0) ? string.Join(", ", roles) : "Rol atanmadı")</span></div>
                        </div>
                    </div>
                    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                        <h2 class="text-lg font-semibold text-slate-800">Hızlı işlemler</h2>
                        <div class="mt-4 space-y-3">
                            <a href="@Url.Action("Edit", new { id = Model.Id })" class="flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 hover:border-primary hover:text-primary">Profili Güncelle <span>→</span></a>
                            <a href="@Url.Action("ManageRoles", new { id = Model.Id })" class="flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 hover:border-primary hover:text-primary">Rol Yönetimi <span>→</span></a>
                            <a href="@Url.Action("UserPolicies", "PolicyManagement", new { userId = Model.Id })" class="flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 hover:border-primary hover:text-primary">Poliçe Geçmişi <span>→</span></a>
                        </div>
                    </div>
                </div>
            </div>
