@model Mvc_LifeSure_DbFirst.Dtos.AppUserDtos.ResultAppUserDto
@using System.Collections.Generic
@{
    ViewBag.Title = "Kullanıcı Detayı";
    ViewBag.PageTitle = "Kullanıcı Detayı";
    ViewBag.BreadcrumbTitle = "Kullanıcılar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var roles = ViewBag.UserRoles as IList<string>;
}

<div class="p-8">
    <div class="max-w-3xl bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 space-y-2">
        <h2 class="text-xl font-semibold">@Model.FirstName @Model.LastName</h2>
        <p><strong>Kullanıcı Adı:</strong> @Model.UserName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Telefon:</strong> @Model.PhoneNumber</p>
        <p><strong>Şehir:</strong> @Model.City</p>
        <p><strong>Poliçe Sayısı:</strong> @Model.PolicyCount</p>
        <p><strong>Roller:</strong> @((roles != null && roles.Count > 0) ? string.Join(", ", roles) : "Rol yok")</p>
        <a href="@Url.Action("Index")" class="inline-block mt-2 px-4 py-2 rounded-xl bg-primary text-white">Listeye Dön</a>
    </div>
</div>