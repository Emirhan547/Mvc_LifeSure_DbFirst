@{
    ViewBag.Title = "Poliçe Satış Tahminleme";
    ViewBag.PageTitle = "Poliçe Satış Tahminleme";
    ViewBag.BreadcrumbTitle = "ML Tahmin";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@* Export formu - CSRF token taşır *@
@using (Html.BeginForm("ExportForecast", "Forecast", new { area = "Admin" }, FormMethod.Post, new { id = "exportForm" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="city" id="exportCity" />
    <input type="hidden" name="months" id="exportMonths" />
}
@* Genel AJAX token formu *@
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "antiForgeryForm", style = "display:none;" }))
{
    @Html.AntiForgeryToken()
}

<div class="p-8 space-y-6">

  
    <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
        <h1 class="text-2xl font-bold">ML ile Poliçe Satış Tahmini</h1>
        <p class="mt-1 text-sm text-white/90">Şehir bazlı satış ve prim tahminleri; model eğitimi ve CSV dışa aktarımı.</p>
    </div>

  
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 space-y-4">
        <h2 class="text-lg font-semibold text-slate-800">Tahmin Parametreleri</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Şehir</label>
                <select id="citySelect"
                        class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                    <option value="">-- Şehir Seçin --</option>
                    @foreach (var city in ViewBag.Cities)
                    {
                        <option value="@city">@city</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Tahmin Süresi</label>
                <select id="monthsSelect"
                        class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary">
                    <option value="3">3 Ay</option>
                    <option value="6" selected>6 Ay</option>
                    <option value="12">12 Ay</option>
                </select>
            </div>
            <div class="flex items-end">
                <button id="forecastBtn"
                        class="w-full px-4 py-2.5 rounded-xl bg-primary text-white font-medium hover:bg-cyan-600 transition-colors text-sm">
                    Tahmin Yap
                </button>
            </div>
        </div>

        <div class="flex flex-wrap gap-2 pt-1">
            <button id="trainModelBtn"
                    class="px-4 py-2 rounded-xl border border-slate-300 text-slate-600 hover:border-primary hover:text-primary transition-colors text-sm">
                Model Eğit
            </button>
            <button id="validateBtn"
                    class="px-4 py-2 rounded-xl border border-slate-300 text-slate-600 hover:border-emerald-500 hover:text-emerald-600 transition-colors text-sm">
                Doğruluk Testi
            </button>
            <button id="exportBtn"
                    class="px-4 py-2 rounded-xl border border-slate-300 text-slate-600 hover:border-amber-500 hover:text-amber-600 transition-colors text-sm">
                CSV İndir
            </button>
        </div>
    </div>

  
    <div id="resultPanel" class="hidden space-y-4">

     
        <div id="loadingIndicator" class="hidden bg-white rounded-2xl border border-slate-200 p-10 text-center">
            <div class="inline-block w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin mb-3"></div>
            <p class="text-slate-500 text-sm">ML modeli tahmin yapıyor…</p>
        </div>

      
        <div id="errorBox" class="hidden bg-rose-50 border border-rose-200 text-rose-700 rounded-2xl px-5 py-4 text-sm"></div>

      
        <div id="metricsRow" class="grid grid-cols-2 md:grid-cols-4 gap-4"></div>

      
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
            <h2 class="text-lg font-semibold text-slate-800 mb-4" id="chartTitle">Tahmin Grafiği</h2>
            <canvas id="forecastChart" style="max-height:300px;"></canvas>
        </div>

     
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-left text-slate-700 font-semibold">
                    <tr>
                        <th class="px-4 py-3">Dönem</th>
                        <th class="px-4 py-3">Tahmini Satış</th>
                        <th class="px-4 py-3">Tahmini Prim</th>
                        <th class="px-4 py-3">Alt Limit</th>
                        <th class="px-4 py-3">Üst Limit</th>
                        <th class="px-4 py-3">Güven Aralığı</th>
                    </tr>
                </thead>
                <tbody id="forecastTableBody"></tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(function () {
            var token = $("#antiForgeryForm input[name='__RequestVerificationToken']").val();
            var chart = null;

            function buildData(extra) {
                return $.extend({ __RequestVerificationToken: token }, extra);
            }

            function getSelectedCity() {
                var city = $("#citySelect").val();
                if (!city) { alert("Lütfen bir şehir seçin."); return null; }
                return city;
            }

            function showLoading(show) {
                if (show) {
                    $("#resultPanel").removeClass("hidden");
                    $("#loadingIndicator").removeClass("hidden");
                    $("#errorBox").addClass("hidden");
                    $("#metricsRow, #forecastTableBody").empty();
                } else {
                    $("#loadingIndicator").addClass("hidden");
                }
            }

            function showError(msg) {
                showLoading(false);
                $("#errorBox").removeClass("hidden").text(msg);
            }

            function buildMetricCard(title, value, sub) {
                return '<div class="bg-slate-50 rounded-xl p-4 text-center">' +
                    '<p class="text-xs text-slate-500 mb-1">' + title + '</p>' +
                    '<p class="text-2xl font-bold text-slate-800">' + value + '</p>' +
                    '<p class="text-xs text-slate-400 mt-1">' + sub + '</p>' +
                    '</div>';
            }

            // ---- Tahmin ----
            $("#forecastBtn").click(function () {
                var city = getSelectedCity(); if (!city) return;
                var months = $("#monthsSelect").val();
                showLoading(true);
                $("#chartTitle").text(city + " — " + months + " Aylık Tahmin");

                $.ajax({
                    url: '@Url.Action("GetForecast", "Forecast", new { area = "Admin" })',
                    type: "POST",
                    data: buildData({ city: city, months: months }),
                    success: function (r) {
                        showLoading(false);
                        if (!r.success) { showError(r.message); return; }
                        renderForecast(r.data);
                    },
                    error: function () { showError("Tahmin alınırken sunucu hatası oluştu."); }
                });
            });

            function renderForecast(data) {
                var totalSales = data.reduce(function (s, d) { return s + d.predictedSales; }, 0);
                var totalPremium = data.reduce(function (s, d) { return s + d.predictedPremium; }, 0);
                var avgSales = totalSales / data.length;
                var avgPremium = totalPremium / data.length;

                $("#metricsRow")
                    .append(buildMetricCard("Toplam Satış", Math.round(totalSales) + " adet", "tahmin"))
                    .append(buildMetricCard("Toplam Prim", Math.round(totalPremium).toLocaleString("tr-TR") + " ₺", "tahmin"))
                    .append(buildMetricCard("Ort. Satış", Math.round(avgSales) + " adet/ay", "aylık"))
                    .append(buildMetricCard("Ort. Prim", Math.round(avgPremium).toLocaleString("tr-TR") + " ₺", "aylık"));

                var tbody = "";
                $.each(data, function (i, item) {
                    var range = Math.round((item.confidenceUpper - item.confidenceLower) / 2);
                    tbody += "<tr class='border-t border-slate-100'>" +
                        "<td class='px-4 py-3 font-medium text-slate-700'>" + item.period + "</td>" +
                        "<td class='px-4 py-3 text-slate-600'>" + Math.round(item.predictedSales) + " adet</td>" +
                        "<td class='px-4 py-3 text-slate-600'>" + Math.round(item.predictedPremium).toLocaleString("tr-TR") + " ₺</td>" +
                        "<td class='px-4 py-3 text-slate-600'>" + Math.round(item.confidenceLower) + "</td>" +
                        "<td class='px-4 py-3 text-slate-600'>" + Math.round(item.confidenceUpper) + "</td>" +
                        "<td class='px-4 py-3 text-slate-600'>±" + range + " adet</td>" +
                        "</tr>";
                });
                $("#forecastTableBody").html(tbody);

                if (chart) chart.destroy();
                chart = new Chart(document.getElementById("forecastChart"), {
                    type: "line",
                    data: {
                        labels: data.map(function (d) { return d.period; }),
                        datasets: [
                            {
                                label: "Tahmini Satış",
                                data: data.map(function (d) { return d.predictedSales; }),
                                borderColor: "#1193d4",
                                backgroundColor: "rgba(17,147,212,0.08)",
                                tension: 0.4,
                                fill: true,
                                pointRadius: 4
                            },
                            {
                                label: "Alt Limit",
                                data: data.map(function (d) { return d.confidenceLower; }),
                                borderColor: "rgba(239,68,68,0.4)",
                                borderDash: [5, 5],
                                fill: false,
                                pointRadius: 0
                            },
                            {
                                label: "Üst Limit",
                                data: data.map(function (d) { return d.confidenceUpper; }),
                                borderColor: "rgba(34,197,94,0.4)",
                                borderDash: [5, 5],
                                fill: false,
                                pointRadius: 0
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: "bottom" },
                            tooltip: {
                                callbacks: {
                                    label: function (ctx) {
                                        return ctx.dataset.label + ": " + Math.round(ctx.raw) + " adet";
                                    }
                                }
                            }
                        },
                        scales: { y: { beginAtZero: true } }
                    }
                });
            }

            // ---- Model Eğit ----
            $("#trainModelBtn").click(function () {
                var city = getSelectedCity(); if (!city) return;
                if (!confirm(city + " için ML modeli eğitmek istediğinize emin misiniz?")) return;

                $.ajax({
                    url: '@Url.Action("TrainModel", "Forecast", new { area = "Admin" })',
                    type: "POST",
                    data: buildData({ city: city }),
                    success: function (r) {
                        if (r.success) {
                            var d = r.data;
                            alert("Model eğitildi!\nR² Skoru: " + d.rScore.toFixed(3) +
                                "\nOrtalama Hata: " + d.meanAbsoluteError.toFixed(2) + " adet" +
                                "\nVeri Sayısı: " + d.dataPointCount);
                        } else {
                            alert("Hata: " + r.message);
                        }
                    },
                    error: function () { alert("Sunucu hatası oluştu."); }
                });
            });

            // ---- Doğruluk Testi ----
            $("#validateBtn").click(function () {
                var city = getSelectedCity(); if (!city) return;
                $.ajax({
                    url: '@Url.Action("ValidateForecast", "Forecast", new { area = "Admin" })',
                    type: "POST",
                    data: buildData({ city: city }),
                    success: function (r) {
                        if (r.success) {
                            alert(city + " için tahmin doğruluğu: %" + r.accuracy);
                        } else {
                            alert("Hata: " + r.message);
                        }
                    },
                    error: function () { alert("Sunucu hatası oluştu."); }
                });
            });

            // ---- CSV İndir ----
            $("#exportBtn").click(function () {
                var city = getSelectedCity(); if (!city) return;
                $("#exportCity").val(city);
                $("#exportMonths").val($("#monthsSelect").val());
                $("#exportForm").submit();
            });
        });
    </script>
}
