@{
    ViewBag.Title = "Tahmin Dashboard";
    ViewBag.PageTitle = "Tahmin Dashboard";
    ViewBag.BreadcrumbTitle = "Dashboard";
    var forecastYear = DateTime.Now.Year;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<div class="p-8 space-y-6">
    <div class="rounded-2xl bg-gradient-to-r from-primary to-cyan-500 p-6 text-white shadow-lg shadow-primary/20">
        <h1 class="text-2xl font-bold">@ViewBag.PageTitle</h1>
        <p class="mt-1 text-sm text-white/90">Yönetim ekranı temayla uyumlu olacak şekilde güncellendi.</p>
    </div>
</div>

<style>
    @using (Html.BeginForm(null, null, FormMethod.Post, new { id = "antiForgeryForm", style = "display:none;" }))
{
    @Html.AntiForgeryToken()
}
    .card {
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 1px 2px rgba(15,23,42,.06)
    }

    .card-header {
        border-top-left-radius: 1rem !important;
        border-top-right-radius: 1rem !important;
        background: linear-gradient(90deg,#0ea5e9,#06b6d4) !important;
        color: #fff !important;
        border-bottom: 1px solid #e2e8f0
    }

    .table-light {
        background: #f8fafc !important
    }
</style>
@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "antiForgeryForm", style = "display:none;" }))
{
    @Html.AntiForgeryToken()
}
<div class="row">
    <div class="col-12 mb-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>@forecastYear Yılı Çeyreklik Tahminler</h5>
            </div>
            <div class="card-body">
                <div class="row" id="quarterlyForecast"></div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-city me-2"></i>Şehir Bazlı Satış Tahminleri</h5>
            </div>
            <div class="card-body">
                <canvas id="cityChart" style="height: 300px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Aylık Trend</h5>
            </div>
            <div class="card-body">
                <canvas id="trendChart" style="height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var antiForgeryToken = '';
        $(document).ready(function () {
            antiForgeryToken = $("#antiForgeryForm input[name='__RequestVerificationToken']").val();
            loadDashboardData();
        });

        function loadDashboardData() {
            $.ajax({
                url: '@Url.Action("GetDashboardData")',
                type: 'POST',
                data: { __RequestVerificationToken: antiForgeryToken },
                success: function(response) {
                    if(response.success) {
                        displayQuarterlyForecast(response.yearly);
                        displayCityChart(response.forecasts);
                        displayTrendChart(response.forecasts);
                    }
                }
            });
        }

        function displayQuarterlyForecast(data) {
            var html = '';
            var cities = [...new Set(data.map(item => item.city))];

            cities.forEach(city => {
                var cityData = data.filter(d => d.city === city);
                html += `
                    <div class="col-md-3 mb-3">
                        <div class="card h-100">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">${city}</h6>
                            </div>
                            <div class="card-body p-2">
                `;

                cityData.forEach(q => {
                    html += `
                        <div class="mb-2 p-2 border-bottom">
                            <small class="text-muted">${q.year} Q${q.quarter}</small>
                            <div class="d-flex justify-content-between">
                                <span>${Math.round(q.predictedTotalSales)} poliçe</span>
                                <span class="text-primary">${Math.round(q.predictedTotalPremium / 1000)}K ₺</span>
                            </div>
                        </div>
                    `;
                });

                html += `</div></div></div>`;
            });

            $("#quarterlyForecast").html(html);
        }

        function displayCityChart(forecasts) {
            var cities = Object.keys(forecasts);
            var totalSales = cities.map(city =>
                forecasts[city].reduce((sum, item) => sum + item.predictedSales, 0)
            );

            new Chart(document.getElementById('cityChart'), {
                type: 'bar',
                data: {
                    labels: cities,
                    datasets: [{
                        label: 'Tahmini Toplam Satış',
                        data: totalSales,
                        backgroundColor: '#0d6efd'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        function displayTrendChart(forecasts) {
            var cities = Object.keys(forecasts).slice(0, 5); // İlk 5 şehir
            var datasets = [];
            var months = ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran'];

            cities.forEach((city, index) => {
                var cityData = forecasts[city];
                datasets.push({
                    label: city,
                    data: cityData.map(d => d.predictedSales),
                    borderColor: `hsl(${index * 70}, 70%, 50%)`,
                    tension: 0.4
                });
            });

            new Chart(document.getElementById('trendChart'), {
                type: 'line',
                data: {
                    labels: months,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false
                }
            });
        }
    </script>
}