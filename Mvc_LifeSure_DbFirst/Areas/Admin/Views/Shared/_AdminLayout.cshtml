<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - LifeSure Yönetim Paneli</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1193d4",
                        "background-light": "#f6f7f8",
                        "background-dark": "#101c22",
                    },
                    fontFamily: {
                        "display": ["Public Sans", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "1rem",
                        "lg": "2rem",
                        "xl": "3rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Public Sans', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Aktif menü öğesi vurgusu — JS ile .active class eklenebilir */
        nav a.active {
            background-color: #1193d4;
            color: #fff;
            box-shadow: 0 8px 16px -4px rgba(17,147,212,0.3);
        }

            nav a.active .material-symbols-outlined {
                color: #fff;
            }
        /* Scroll çubuğu ince stil */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

        .dark ::-webkit-scrollbar-thumb {
            background: #334155;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 antialiased">
    <div class="flex h-screen overflow-hidden">

        <!-- ===================== KENAR ÇUBUĞU ===================== -->
        <aside class="w-72 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col h-full overflow-y-auto shrink-0">

            <!-- Logo -->
            <div class="p-8 flex items-center gap-3">
                <div class="size-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary/30">
                    <span class="material-symbols-outlined text-2xl">shield_person</span>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white leading-none">LifeSure</h1>
                    <p class="text-xs text-slate-500 font-medium">Kurumsal Sigorta</p>
                </div>
            </div>

            <!-- Navigasyon -->
            <nav class="flex-1 px-4 space-y-1">
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Dashboard", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">dashboard</span>
                    <span class="text-sm font-medium">Gösterge Paneli</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "About", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">info</span>
                    <span class="text-sm font-medium">Hakkımızda</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Slider", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">view_carousel</span>
                    <span class="text-sm font-medium">Slider</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Feature", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">star</span>
                    <span class="text-sm font-medium">Özellikler</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Service", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">handshake</span>
                    <span class="text-sm font-medium">Hizmetler</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Faq", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">quiz</span>
                    <span class="text-sm font-medium">SSS Yönetimi</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Blog", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">article</span>
                    <span class="text-sm font-medium">Blog Yönetimi</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Team", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">groups</span>
                    <span class="text-sm font-medium">Ekip</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Testimonial", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">reviews</span>
                    <span class="text-sm font-medium">Referanslar</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "ContactMessage", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">mark_email_read</span>
                    <span class="text-sm font-medium">İletişim Mesajları</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "UserManagement", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">manage_accounts</span>
                    <span class="text-sm font-medium">Kullanıcılar</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "PackageManagement", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">inventory_2</span>
                    <span class="text-sm font-medium">Paketler</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "PolicyManagement", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">policy</span>
                    <span class="text-sm font-medium">Poliçeler</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "Forecast", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">monitoring</span>
                    <span class="text-sm font-medium">Tahmin</span>
                </a>
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "TavilySearch", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">travel_explore</span>
                    <span class="text-sm font-medium">Tavily Arama</span>
                </a>
            </nav>

            <!-- Alt İşlemler -->
            <div class="px-4 py-6 border-t border-slate-200 dark:border-slate-800 mt-auto">
                <a class="flex items-center gap-3 px-4 py-3 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all group"
                   href='@Url.Action("Index", "DataGenerator", new { area = "Admin" })'>
                    <span class="material-symbols-outlined group-hover:text-primary">database</span>
                    <span class="text-sm font-medium">Veri Üretici</span>
                </a>
                @using (Html.BeginForm("Logout", "Account", new { area = "" }, FormMethod.Post, new { @class = "m-0" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl transition-all text-left">
                        <span class="material-symbols-outlined">logout</span>
                        <span class="text-sm font-medium">Çıkış Yap</span>
                    </button>
                }
            </div>
        </aside>

        <!-- ===================== ANA İÇERİK ===================== -->
        <main class="flex-1 flex flex-col min-w-0 overflow-hidden">

            <!-- ===================== BAŞLIK ÇUBUĞU ===================== -->
            <header class="h-20 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-8 flex items-center justify-between sticky top-0 z-10 shrink-0">
                <div class="flex items-center gap-6">

                    <!-- Sayfa Başlığı & Ekmek Kırıntısı -->
                    <div>
                        <h2 class="text-xl font-bold text-slate-900 dark:text-white leading-none">
                            @(ViewBag.PageTitle ?? "Yönetim Paneli")
                        </h2>
                        <div class="flex items-center gap-1.5 text-xs text-slate-400 font-medium mt-1">
                            <a class="hover:text-primary transition-colors" href='@Url.Action("Index", "Dashboard", new { area = "Admin" })'>LifeSure</a>
                            <span class="material-symbols-outlined" style="font-size:10px">chevron_right</span>
                            <span>@(ViewBag.BreadcrumbTitle ?? "Genel Bakış")</span>
                        </div>
                    </div>

                    <!-- Arama -->
                    <div class="hidden md:flex relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">search</span>
                        <input class="pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-xl text-sm w-64 focus:ring-2 focus:ring-primary focus:bg-white dark:focus:bg-slate-700 transition-all outline-none"
                               placeholder="Genel Arama..."
                               type="text" />
                    </div>
                </div>

                <!-- Sağ Eylemler -->
                <div class="flex items-center gap-3">
                    <!-- Bildirim -->
                    <button class="size-10 rounded-full flex items-center justify-center text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 relative transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2.5 size-2 bg-red-500 rounded-full border-2 border-white dark:border-slate-900"></span>
                    </button>
                    <!-- Mesaj -->
                    <button class="size-10 rounded-full flex items-center justify-center text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors">
                        <span class="material-symbols-outlined">mail</span>
                    </button>

                    <div class="h-8 w-px bg-slate-200 dark:bg-slate-700 mx-1"></div>

                    <!-- Kullanıcı Profili -->
                    <button class="flex items-center gap-3 p-1 pl-3 pr-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-all border border-slate-200 dark:border-slate-700 shadow-sm">
                        <div class="text-right hidden sm:block">
                            <p class="text-sm font-bold text-slate-900 dark:text-white leading-none">
                                @(ViewBag.AdminName ?? "Yönetici")
                            </p>
                            <p class="text-[10px] text-slate-400 font-medium uppercase tracking-wider mt-0.5">
                                @(ViewBag.AdminRole ?? "Süper Admin")
                            </p>
                        </div>
                        <div class="size-9 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center text-primary font-bold text-sm overflow-hidden">
                            @{
                                var adminName = ViewBag.AdminName as string ?? "A";
                                var initials = adminName.Length > 0 ? adminName[0].ToString().ToUpper() : "A";
                            }
                            @initials
                        </div>
                    </button>
                </div>
            </header>

            <!-- ===================== SAYFA İÇERİĞİ — RenderBody ===================== -->
            <div class="flex-1 overflow-y-auto">
                @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
                {
                    <div class="px-8 pt-6">
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm font-medium text-emerald-700">@TempData["SuccessMessage"]</div>
                        }
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="mt-3 rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-medium text-rose-700">@TempData["ErrorMessage"]</div>
                        }
                    </div>
                }
                @RenderBody()
            </div>

        </main>
    </div>

    <!-- Aktif menü öğesini otomatik vurgula -->
    <script>
        (function () {
            var path = window.location.pathname.toLowerCase();
            document.querySelectorAll('nav a').forEach(function (link) {
                var href = link.getAttribute('href');
                if (href && href !== '#' && path.indexOf(href.toLowerCase().split('?')[0]) !== -1) {
                    link.classList.add('active');
                    link.classList.remove('text-slate-600', 'dark:text-slate-400', 'hover:bg-slate-100', 'dark:hover:bg-slate-800');
                }
            });
        })();
    </script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
